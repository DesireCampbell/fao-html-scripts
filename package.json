{
  "name": "fao-html-scripts",
  "displayName": "FAO HTML Scripts",
  "description": "A collection of scripts to help in HTML production",
  "repository": {
    "type": "git",
    "url": "https://github.com/DesireCampbell/fao-html-scripts.git"
  },
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fao-html-scripts.helloWorld",
        "title": "FAO Hello World"
      },
      {
        "command": "fao-html-scripts.pasteAsHTML",
        "title": "FAO Paste as HTML"
      },
      {
        "command": "fao-html-scripts.stripStyles",
        "title": "FAO Strip Styles"
      },
      {
        "command": "fao-html-scripts.formatCharts",
        "title": "FAO Format Charts"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "fao-html-scripts.pasteAsHTML",
          "when": "editorTextFocus"
        },
        {
          "command": "fao-html-scripts.stripStyles",
          "when": "editorTextFocus"
        },
        {
          "command": "fao-html-scripts.formatCharts",
          "when": "editorTextFocus"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fao-html-scripts",
          "title": "FAO HTML Scripts",
          "icon": "resources/icon.png"
        }
      ]
    },
    "viewsWelcome": [
			{
				"view": "fao-html-scripts-view",
				"contents": "You can have paragraphs of text here. You can have [links](https://code.visualstudio.com) to external sources or [internal commands](command:welcome-view-content-sample.hello).\nUse new lines to have new paragraphs.\nPlace a link alone in a paragraph to make it a button\n[Hello](command:welcome-view-content-sample.hello)\n You can also render [codicons](https://microsoft.github.io/vscode-codicons/dist/codicon.html) using the $(...) syntax like: $(vscode) $(heart) $(github)\nAdd a little $(sparkle) to your welcome views!\n\n\n[$(clippy) Paste as HTML](command:fao-html-scripts.pasteAsHTML)\n\n[Strip Styles](command:fao-html-scripts.stripStyles)\n\n[Format Charts](command:fao-html-scripts.formatCharts)"
			}
		],
    "views": {
      "fao-html-scripts": [
        {
          "id": "fao-html-scripts-view",
          "name": "FAO HTML Scripts"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
